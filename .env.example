# Local storage
NICO_HOME=.nico
NICO_DB_PATH=.nico/nico.sqlite3
NICO_REPORT_DIR=.nico/reports

# Local API
NICO_API_HOST=127.0.0.1
NICO_API_PORT=8000
NICO_API_RELOAD=true
NICO_CORS_ORIGINS=http://localhost:3000

# Defensive execution boundaries
NICO_AUTONOMY_LEVEL=1
NICO_ENABLE_SCANNER_EXECUTION=true
NICO_ALLOW_PROJECT_COMMANDS=false
NICO_ENABLE_FULL_HISTORY_SECRET_SCAN=false
NICO_MAX_REPO_BYTES=150000000
NICO_TOOL_TIMEOUT_SECONDS=45
NICO_TOTAL_SCAN_TIMEOUT_SECONDS=300
NICO_MAX_TOOL_OUTPUT=12000

# Production-only examples; leave unset for local SQLite operation.
# DATABASE_URL=postgresql://user:password@host:5432/nico
# NICO_ADMIN_TOKEN=generate-a-long-random-secret
# NICO_EXPECTED_BUILD_SHA=full-40-character-commit-sha
